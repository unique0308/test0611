# =============================================================================
# AI 中台 MVP · 环境变量模板
# =============================================================================
# 复制为 .env.local 后填入真实值;.env.local 绝不进 git
# 真实值集中存档在 ../LOCAL_SECRETS.md(工程外,跟工程同级)
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 32 字节随机:openssl rand -base64 32
SESSION_SECRET=

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# 新版 API Keys(2025+):publishable key 对应旧版 anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 新版 API Keys:secret key 对应旧版 service_role key;⚠️ 仅后端用,禁止暴露给前端
SUPABASE_SERVICE_ROLE_KEY=
# PG 直连字符串(跑 migration / 一次性脚本用,生产部署可不配)
DATABASE_URL=

# ─── 抽象层模式开关 ──────────────────────────────────────────────────────────
# EASYROUTER_MODE 2026-05-18 加入(原决策 11"easyrouter 不走 mock"已被临时推翻)
AUTH_MODE=mock                # mock | real
STORAGE_MODE=local            # local | oss
NOTIFICATION_MODE=mock        # mock | feishu
MONITORING_MODE=noop          # noop | sentry
EASYROUTER_MODE=mock          # mock | real(real 时走 lib/easyrouter/client.ts 真实 HTTP)

# ─── 飞书 SSO(AUTH_MODE=mock 时不读取)──────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:3000/api/auth/feishu/callback

# ─── 模型聚合 API · provider-based(Day 3.5)──────────────────────────────────
# 每个 provider 独立 key,业务代码透明无感(只看 model.provider 字段路由)
# 缺 key 的 provider:model 行 enabled=false,前端不展示
#
# OpenRouter(图片;Gemini Flash Image / GPT Image 系列)
OPENROUTER_API_KEY=

# 火山方舟(视频;Seedance / Seedream)
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# aihubmix(图片;OpenAI 兼容)
AIHUBMIX_BASE_URL=
AIHUBMIX_API_KEY=

# 通用
EASYROUTER_IMAGE_TIMEOUT_MS=120000
USD_TO_CNY=7.2

# ─── 阿里云 OSS(STORAGE_MODE=local 时不读取)───────────────────────────────
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_REGION=oss-cn-shanghai
ALIYUN_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# ─── 飞书机器人(NOTIFICATION_MODE=mock 时不读取)───────────────────────────
FEISHU_BOT_WEBHOOK=
FEISHU_BOT_SECRET=

# ─── Sentry(MONITORING_MODE=noop 时不读取)──────────────────────────────────
SENTRY_DSN=

# ─── Admin 白名单(逗号分隔多个邮箱)─────────────────────────────────────────
ADMIN_EMAILS=

# ─── 开发模式专用(仅 AUTH_MODE=real 时使用,生产环境禁止存在)──────────────
# mock 模式下用 /auth/dev 切身份,无需此变量
DEV_MOCK_USER_EMAIL=
